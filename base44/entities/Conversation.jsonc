{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "participant_emails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "booking_id": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_at": {
      "type": "string"
    },
    "last_message_by": {
      "type": "string"
    },
    "unread_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "participant_emails"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "$or": [
        {
          "participant_emails": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "participant_emails": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}